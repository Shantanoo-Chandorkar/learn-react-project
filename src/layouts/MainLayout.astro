---
/**
 * MainLayout.astro
 *
 * The root HTML shell for every page. Imports all global CSS, mounts
 * the Header and Sidebar as React islands (client:load so they hydrate
 * immediately and share the Zustand store), and provides a <slot /> for
 * page-specific content.
 *
 * OG / social meta tags are optional props — the topic page passes them
 * at build time so every crawlable URL gets proper previews without an
 * edge function.
 */
import Header from '../components/layout/Header.jsx';
import Sidebar from '../components/layout/Sidebar.jsx';
import '../index.css';
import '../App.css';
import '../components/layout/Layout.css';

interface Props {
    title?: string;
    description?: string;
    ogTitle?: string;
    ogImage?: string;
    ogUrl?: string;
    currentPath?: string;
}

const {
    title = 'EscapeTheSurface',
    description = 'Master the internal mechanisms of the Frontend. A deep-dive platform for engineering high-caliber React developers.',
    ogTitle,
    ogImage,
    ogUrl,
    currentPath = Astro.url.pathname,
} = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <meta name="description" content={description} />

        <style is:inline>
            :root {
                --primary-color: #2563eb;
                --bg-color: #f8fafc;
                --text-color: #1e293b;
                --font-serif: 'Georgia', 'Times New Roman', Times, serif;
            }
            body {
                margin: 0;
                font-family: system-ui, -apple-system, sans-serif;
                background-color: #f8fafc;
                color: #1e293b;
                line-height: 1.5;
            }
            .layout-root {
                display: flex;
                flex-direction: column;
                height: 100vh;
                overflow: hidden;
            }
            .layout-body {
                display: flex;
                flex: 1;
                overflow: hidden;
            }
            .layout-content {
                flex: 1;
                padding: 2rem;
                overflow-y: auto;
            }
            @media (max-width: 1024px) {
                .layout-content { padding: 1rem; }
            }
        </style>

        {ogTitle && <meta property="og:type" content="article" />}
        {ogTitle && <meta property="og:title" content={ogTitle} />}
        {ogTitle && <meta property="og:description" content={description} />}
        {ogUrl && <meta property="og:url" content={ogUrl} />}
        {ogImage && <meta property="og:image" content={ogImage} />}
        {ogImage && <meta property="og:image:width" content="1200" />}
        {ogImage && <meta property="og:image:height" content="630" />}
        {ogImage && <meta name="twitter:card" content="summary_large_image" />}
        {ogImage && <meta name="twitter:image" content={ogImage} />}
    </head>
    <body>
        <div class="layout-root">
            <Header client:load />
            <div class="layout-body">
                <Sidebar currentPath={currentPath} client:visible />
                <main class="layout-content">
                    <slot />
                </main>
            </div>
        </div>
    </body>
</html>
